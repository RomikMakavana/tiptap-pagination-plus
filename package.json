    "@tiptap/extension-table-header": "^3.22.4",
    "@tiptap/extension-table-row": "^3.22.4",
    "@tiptap/pm": "^3.22.2",
    "@tiptap/starter-kit": "^3.22.4",
    "@types/node": "^22.15.2",
    "esbuild": "^0.28.0",
    "puppeteer": "^24.42.0",
    "tsc-watch": "^6.0.4",
    "typescript": "^5.8.3"
  },
