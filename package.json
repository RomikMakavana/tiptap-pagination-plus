{
  "name": "tiptap-pagination-plus",
  "version": "3.0.6",
  "description": "Tiptap pagination extension with advanced options like automatic page breaks, customizable layouts and more.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsc",
    "prepare": "tsc",
    "watch": "tsc-watch --onSuccess \"echo 'Build completed'\"",
    "perf:build": "node perf/build.mjs",
    "perf:serve": "node perf/build.mjs && node perf/serve.mjs",
    "test:perf": "node perf/measure.mjs"
  },
  "keywords": [
    "tiptap",
    "tiptap extension",
    "pagination",
    "page",
    "break",
